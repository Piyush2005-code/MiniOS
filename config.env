# Configuration file for benchmark parameters

# Benchmark iterations
DEFAULT_ITERATIONS=1000000
WARMUP_ITERATIONS=100000

# Number of trials for statistical significance
DEFAULT_TRIALS=10

# Model architecture
INPUT_SIZE=784
HIDDEN_SIZE=128
OUTPUT_SIZE=10

# Compiler flags
CC=gcc
CFLAGS="-O3 -march=native -mavx2 -mfma -ffast-math -flto -static -Wall"
LDFLAGS="-lm"

# Unikraft configuration
UNIKRAFT_MEMORY=256M
UNIKRAFT_CPU=1

# Output settings
RESULTS_DIR=results
ENABLE_DETAILED_LOGGING=1
